{
    "name": "@obusk/warcraftlogs-search",
    "private": true,
    "version": "",
    "type": "module",
    "description": "Thing to try to find rankings on Warcraftlogs",
    "keywords": [
        "warcraftlogs",
        "wcl",
        "world of warcraft",
        "wow",
        "wowanalyzer"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oBusk/warcraftlogs-search.git"
    },
    "author": "Oscar Busk <oscar.busk@gmail.com>",
    "license": "ISC",
    "engines": {
        "node": "24.x"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "^24.18.0",
            "onFail": "download"
        }
    },
    "packageManager": "pnpm@11.16.0",
    "simple-git-hooks": {
        "pre-commit": "pnpm run lint-staged"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js,jsx}": [
            "eslint --fix"
        ],
        "**/*.{md,yml,yaml,json}": [
            "prettier --write"
        ]
    },
    "scripts": {
        "dev": "next dev --turbopack -p 3001",
        "build": "next build",
        "start": "next start -p 3001",
        "lint": "eslint .",
        "postlint": "pnpm run prettier",
        "lint-fix": "eslint --fix .",
        "prettier": "prettier **/*.{md,yml,yaml,json} --ignore-path .gitignore --ignore-path .prettierignore --check",
        "postlint-fix": "pnpm run prettier-fix",
        "prettier-fix": "prettier **/*.{md,yml,yaml,json} --ignore-path .gitignore --ignore-path .prettierignore --write",
        "lint-staged": "lint-staged",
        "test": "jest",
        "test-ci": "jest --ci"
    },
    "dependencies": {
        "@vercel/analytics": "^2.0.1",
        "downshift": "^9.4.0",
        "lucide-react": "^0.563.0",
        "next": "16.2.11",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "tailwind-merge": "^2.6.1"
    },
    "devDependencies": {
        "@obusk/eslint-config-next": "^16.2.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "~6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/node": "24.10.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "autoprefixer": "^10.5.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "encoding": "^0.1.13",
        "eslint": "^9.39.5",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "lint-staged": "^17.1.0",
        "postcss": "^8.5.20",
        "prettier": "^3.9.5",
        "simple-git-hooks": "^2.13.1",
        "tailwindcss": "^3.4.19",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.3"
    }
}
